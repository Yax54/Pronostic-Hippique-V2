# Flutter/Dart
# Build outputs (exclude to save space)
/build/
/.dart_tool/
.packages
.pub-cache/
.pub/

# IDE
.vscode/
.idea/
*.iml

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
*.temp

# APK / release binaries — use GitHub Releases instead
*.apk
*.aab
*.ipa

# Android signing — NEVER commit these
android/key.properties
*.jks
*.keystore

# Python cache
__pycache__/
*.pyc
*.pyo

# Keep lib/ directory for source code!

